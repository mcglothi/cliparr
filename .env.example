# Core
CLIPARR_ENV=development
CLIPARR_TIMEZONE=America/New_York
CLIPARR_WEB_ORIGIN=http://localhost:3000
CLIPARR_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Database/queue
POSTGRES_DB=cliparr
POSTGRES_USER=cliparr
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://cliparr:change-me@postgres:5432/cliparr
REDIS_URL=redis://redis:6379/0

# Schedule
CLIPARR_DAILY_RUN_CRON=0 6 * * *

# Optional notifications
CLIPARR_WEBHOOK_URL=
